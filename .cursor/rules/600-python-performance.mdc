### Performance Measurement Decorator

```python
import functools
import time
from typing import Any, Callable, Dict, Optional
import logging

logger = logging.getLogger(__name__)

# Counter for tracking calls and timing across the application
_function_stats: Dict[str, Dict] = {}

def timing(name: Optional[str] = None) -> Callable:
    """Decorator for timing function execution with statistics collection.
    
    Args:
        name: Optional name for the timing metric
        
    Returns:
        Decorated function
    """
    def decorator(func: Callable) -> Callable:
        metric_name = name or func.__qualname__
        
        if metric_name not in _function_stats:
            _function_stats[metric_name] = {
                "calls": 0,
                "total_time": 0.0,
                "min_time": float("inf"),
                "max_time": 0.0,
            }
            
        @functools.wraps(func)
        def wrapper(*args: Any, **kwargs: Any) -> Any:
            start_time = time.perf_counter()
            result = func(*args, **kwargs)
            end_time = time.perf_counter()
            
            # Calculate execution time and update stats
            elapsed_time = end_time - start_time
            stats = _function_stats[metric_name]
            
            stats["calls"] += 1
            stats["total_time"] += elapsed_time
            stats["min_time"] = min(stats["min_time"], elapsed_time)
            stats["max_time"] = max(stats["max_time"], elapsed_time)
            
            # Log expensive operations for investigation
            if elapsed_time > 1.0:  # Threshold for logging
                logger.warning(
                    f"Performance alert: {metric_name} took {elapsed_time:.4f}s"
                )
            
            return result
        
        return wrapper
    
    return decorator

def get_performance_stats() -> Dict[str, Dict]:
    """Get collected performance statistics.
    
    Returns:
        Dictionary of performance metrics per function
    """
    result = {}
    
    for name, stats in _function_stats.items():
        calls = stats["calls"]
        if calls > 0:
            result[name] = {
                "calls": calls,
                "total_time": stats["total_time"],
                "avg_time": stats["total_time"] / calls,
                "min_time": stats["min_time"],
                "max_time": stats["max_time"],
            }
    
    return result
```

### Efficient Batch Processing Pattern

```python
import asyncio
from typing import Any, Callable, List, TypeVar

T = TypeVar('T')
R = TypeVar('R')

async def process_in_batches(
    items: List[T],
    processor: Callable[[T], R],
    batch_size: int = 100,
    concurrency: int = 10,
) -> List[R]:
    """Process items in efficient batches with controlled concurrency.
    
    Args:
        items: List of items to process
        processor: Function to process each item
        batch_size: Size of each batch
        concurrency: Maximum concurrent tasks
        
    Returns:
        List of results in same order as input items
    """
    results = [None] * len(items)
    semaphore = asyncio.Semaphore(concurrency)
    
    async def process_item(index: int, item: T) -> None:
        async with semaphore:
            try:
                result = await processor(item)
                results[index] = result
            except Exception as e:
                logger.error(f"Error processing item {index}: {str(e)}")
                results[index] = None
    
    # Process in batches to avoid creating too many tasks at once
    for i in range(0, len(items), batch_size):
        batch = items[i:i+batch_size]
        tasks = [process_item(i+j, item) for j, item in enumerate(batch)]
        await asyncio.gather(*tasks)
    
    return results
```

### Memory-Efficient Data Processing

```python
import itertools
from typing import Dict, Iterable, List, TypeVar

T = TypeVar('T')

def chunk_iterable(iterable: Iterable[T], size: int) -> Iterable[List[T]]:
    """Split iterable into chunks efficiently without loading all into memory.
    
    Args:
        iterable: Input iterable
        size: Chunk size
        
    Returns:
        Iterator of chunks
    """
    iterator = iter(iterable)
    while chunk := list(itertools.islice(iterator, size)):
        yield chunk

def count_frequency(iterable: Iterable[T], limit: int = None) -> Dict[T, int]:
    """Count frequency of items in an iterable efficiently.
    
    Uses Counter with streaming processing for memory efficiency.
    
    Args:
        iterable: Input iterable
        limit: Optional limit on result size
        
    Returns:
        Dictionary with items and counts
    """
    from collections import Counter
    
    # Process in chunks to avoid loading everything into memory
    counter = Counter()
    for chunk in chunk_iterable(iterable, 10000):
        counter.update(chunk)
    
    # Return top N if limit specified
    if limit is not None:
        return dict(counter.most_common(limit))
    
    return dict(counter)
```

