    @measure_memory_usage
    async def crawl(self, start_url: str, max_depth: int = 2) -> Dict:
        """Crawl from start URL with async concurrency and memory tracking.
        
        Args:
            start_url: Starting URL
            max_depth: Maximum crawl depth
            
        Returns:
            Dictionary with crawl results and performance metrics
        """
        to_crawl = [(start_url, 0)]  # (url, depth)
        results = {}
        self.visited_urls = set()
        
        # Process URLs efficiently with bounded concurrency
        tasks = []
        while to_crawl and len(self.visited_urls) < self.max_urls:
            # Get batch of URLs to process (up to concurrency limit)
            batch = []
            while to_crawl and len(batch) < self.concurrency:
                url, depth = to_crawl.pop(0)
                if url not in self.visited_urls:
                    self.visited_urls.add(url)
                    batch.append((url, depth))
            
            if not batch:
                break
                
            # Create fetch tasks for the batch
            tasks = [self._process_url(url, depth, to_crawl, max_depth) for url, depth in batch]
            
            # Process batch concurrently and collect results
            batch_results = await asyncio.gather(*tasks, return_exceptions=True)
            for url, result in ((b[0], r) for b, r in zip(batch, batch_results) if not isinstance(r, Exception)):
                if result:
                    results[url] = result
        
        # Compute and add performance metrics
        metrics = self._get_performance_metrics()
        return {
            "results": results,
            "metrics": metrics,
            "urls_crawled": len(self.visited_urls),
        }
    
    async def _process_url(
        self, 
        url: str, 
        depth: int, 
        to_crawl: List[Tuple[str, int]], 
        max_depth: int
    ) -> Optional[Dict]:
        """Process a single URL with efficient error handling.
        
        Args:
            url: URL to process
            depth: Current depth
            to_crawl: Queue of URLs to crawl
            max_depth: Maximum depth
            
        Returns:
            Processed result or None if failed
        """
        try:
            # Fetch URL with instrumentation
            url, content = await self.fetch_url(url)
            
            # Extract links if not at max depth
            links = []
            if depth < max_depth:
                links = self.parse_links(url, content)
                
                # Add new links to crawl queue
                for link in links:
                    if link not in self.visited_urls:
                        to_crawl.append((link, depth + 1))
            
            # Return result with metadata
            return {
                "content": content[:1000] + "..." if len(content) > 1000 else content,
                "content_size": len(content),
                "links": links,
                "depth": depth,
            }
        except Exception as e:
            logger.warning(f"Error processing {url}: {str(e)}")
            return None
    
    def _get_performance_metrics(self) -> Dict:
        """Calculate performance metrics for instrumentation."""
        if not self.fetch_times:
            return {}
            
        fetch_avg = sum(self.fetch_times) / max(len(self.fetch_times), 1)
        parse_avg = sum(self.parse_times) / max(len(self.parse_times), 1)
        total_time = time.time() - self.start_time
        
        return {
            "total_time_seconds": total_time,
            "urls_per_second": len(self.visited_urls) / total_time if total_time > 0 else 0,
            "avg_fetch_time_ms": fetch_avg * 1000,
            "avg_parse_time_ms": parse_avg * 1000,
            "total_data_size_mb": self.total_data_size / (1024 * 1024),
            "data_throughput_mbps": (self.total_data_size / total_time) / (1024 * 1024) if total_time > 0 else 0,
        }
    
    def _log_performance_metrics(self):
        """Log performance metrics after crawl completion."""
        metrics = self._get_performance_metrics()
        if not metrics:
            return
            
        logger.info(
            f"Crawl completed: "
            f"{len(self.visited_urls)} URLs in {metrics['total_time_seconds']:.2f}s "
            f"({metrics['urls_per_second']:.2f} URLs/s), "
            f"Fetched {metrics['total_data_size_mb']:.2f}MB "
            f"({metrics['data_throughput_mbps']:.2f} MB/s)"
        )


async def batch_crawl(
    urls: List[str],
    concurrency: int = 10,
    max_depth: int = 1,
    timeout: float = 30.0,
) -> Dict:
    """Batch crawl multiple URLs efficiently.
    
    Args:
        urls: List of URLs to crawl
        concurrency: Maximum concurrent requests
        max_depth: Maximum crawl depth per URL
        timeout: Request timeout in seconds
        
    Returns:
        Dictionary with combined results
    """
    # Create crawler with efficient settings
    async with WebCrawler(
        concurrency=concurrency,
        timeout=timeout,
        max_urls=100 * len(urls),  # Adjust based on expected crawl volume
    ) as crawler:
        # Process URLs in parallel batches
        tasks = [crawler.crawl(url, max_depth) for url in urls]
        results = await asyncio.gather(*tasks, return_exceptions=True)
        
        # Combine and return results
        combined = {
            "url_results": {},
            "total_urls_crawled": 0,
            "errors": 0,
        }
        
        for url, result in zip(urls, results):
            if isinstance(result, Exception):
                logger.error(f"Error crawling {url}: {str(result)}")
                combined["url_results"][url] = {"error": str(result)}
                combined["errors"] += 1
            else:
                combined["url_results"][url] = result
                combined["total_urls_crawled"] += result.get("urls_crawled", 0)
                
        return combined
