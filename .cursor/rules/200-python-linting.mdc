    url: str = Field(..., description="Target URL to crawl")
    depth: int = Field(1, description="Crawl depth")  # Missing min/max validation
    follow_links: bool = Field(False, description="Whether to follow links")
    timeout: float = Field(30.0, description="Request timeout in seconds")  # Should be Optional
    
    # Poorly named method
    def check(self):  # Missing return type annotation
        validate_url(self.url)
        return True


# Complex function with linting issues
def process_results(results, output_path=None):  # Missing type annotations
    """Process crawl results"""  # Incomplete docstring
    
    logger = logging.getLogger(__name__)
    
    # Implicit boolean comparison
    if not len(results) > 0:
        logger.warning("No results to process")
        return
    
    # Not handling None correctly
    if output_path == None:
        output_path = Path.home() / "crawl_results.json"
    
    # Bare except
    try:
        with open(output_path, "w") as f:  # Not using pathlib properly
            f.write(json.dumps(results, indent=2))
        logger.info("Results written to %s" % output_path)  # Old-style string formatting
        return output_path
    except:
        logger.error("Failed to write results")
        raise Exception("Write failed")  # Raising generic exception
