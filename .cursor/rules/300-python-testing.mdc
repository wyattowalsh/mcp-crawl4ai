<example>
// EXCELLENT: Well-structured test with fixtures, parameterization, and assertions
```python
"""Tests for the crawl module's URL validation functionality."""

import pytest
from hypothesis import given, strategies as st
from urllib.parse import urlparse

from crawl4ai_mcp.crawler import URLValidator, ValidationError


class TestURLValidator:
    """Test suite for URL validation functionality."""

    @pytest.fixture
    def validator(self) -> URLValidator:
        """Create a properly configured URL validator for testing."""
        return URLValidator(
            allowed_schemes=["http", "https"],
            max_length=2000,
            validate_connection=False,
        )

    def test_validator_initialization(self) -> None:
        """Test that the validator initializes with proper settings."""
        validator = URLValidator(allowed_schemes=["ftp", "sftp"])
        
        assert "ftp" in validator.allowed_schemes
        assert "http" not in validator.allowed_schemes
        assert validator.max_length == 2048  # Default value

    @pytest.mark.parametrize(
        "url,expected_valid",
        [
            ("https://example.com", True),
            ("http://example.com/path?query=value", True),
            ("ftp://example.com", False),  # Wrong scheme
            ("https://" + "a" * 3000, False),  # Too long
            ("not-a-url", False),  # Invalid format
            ("", False),  # Empty string
        ],
    )
    def test_validate_url_with_various_inputs(
        self, validator: URLValidator, url: str, expected_valid: bool
    ) -> None:
        """Test URL validation with various inputs using parameterization."""
        if expected_valid:
            # Should not raise an exception
            validator.validate(url)
        else:
            # Should raise a ValidationError
            with pytest.raises(ValidationError):
                validator.validate(url)

    @given(
        st.text(
            alphabet=st.characters(
                blacklist_categories=["C"],  # Control chars
                blacklist_characters=["\0"],
            ),
            min_size=1,
            max_size=50,
        )
    )
    def test_url_component_validator_with_generated_inputs(
        self, validator: URLValidator, component: str
    ) -> None:
        """Use Hypothesis to test URL component validation with generated inputs."""
        try:
            # Wrap in try/except since some random strings might be invalid URLs
            url = f"https://example.com/{component}"
            result = validator.validate(url)
            
            # If validation succeeded, path should match our component
            parsed = urlparse(url)
            assert parsed.path.lstrip("/") == component
            
        except ValidationError:
            # Some inputs may legitimately cause validation errors
            pass

    @pytest.mark.asyncio
    async def test_async_url_validation(self, validator: URLValidator) -> None:
        """Test async URL validation functionality."""
        # For async tests, use pytest-asyncio marker
        result = await validator.validate_async("https://example.com")
        assert result.is_valid
        assert result.normalized_url == "https://example.com/"

    def test_validation_with_redirects(
        self, validator: URLValidator, mocker: pytest.MockFixture
    ) -> None:
        """Test URL validation handling of redirects using mocking."""
        # Mock the HTTP client used by the validator
        mock_client = mocker.patch("crawl4ai_mcp.crawler.http.client")
        mock_client.get.return_value.status_code = 301
        mock_client.get.return_value.headers = {"Location": "https://new-example.com"}
        
        # With redirects allowed
        validator.follow_redirects = True
        result = validator.validate("https://example.com")
        
        # Verify the validation follows the redirect
        assert result.final_url == "https://new-example.com"
        assert result.redirect_count == 1
```

