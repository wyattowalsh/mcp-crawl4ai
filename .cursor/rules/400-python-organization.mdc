```python
"""URL validation and normalization for the crawl4ai-mcp project.

This module provides utilities for validating, normalizing, and manipulating
URLs for web crawling operations. It includes validation for security,
structure, and accessibility.

Interfaces:
    URLValidator: Main validator class for URL operations
    normalize_url: Function to standardize URL format
    
Implementation Details:
    Uses urllib.parse for URL parsing
    Implements RFC 3986 for URL validation
    Provides synchronous and asynchronous validation methods
"""

import logging
import re
from enum import Enum
from typing import Dict, List, Optional, Protocol, Set, Tuple, Union
from urllib.parse import ParseResult, urlparse, urlunparse

import httpx
from pydantic import BaseModel, Field, validator

# Project-local imports (example)
# from myproject.utils import retry_async, normalize_text


# Constants with clear purposes
DEFAULT_TIMEOUT_SECONDS = 30.0
MAX_URL_LENGTH = 2048
DEFAULT_USER_AGENT = "crawl4ai-mcp/1.0"

# Enum for validation status
class ValidationStatus(str, Enum):
    """Enumeration of URL validation status results."""
    VALID = "valid"
    INVALID_SCHEME = "invalid_scheme"
    INVALID_FORMAT = "invalid_format"
    TOO_LONG = "too_long"
    UNREACHABLE = "unreachable"
    FORBIDDEN = "forbidden"


# Domain models with validation
class ValidationResult(BaseModel):
    """Result of URL validation operation.
    
    Contains validation status, the normalized URL if valid,
    and detailed error information if invalid.
    """
    url: str = Field(..., description="Original URL that was validated")
    status: ValidationStatus = Field(..., description="Validation status")
    normalized_url: Optional[str] = Field(None, description="Normalized URL if valid")
    final_url: Optional[str] = Field(None, description="Final URL after redirects")
    redirect_count: int = Field(0, description="Number of redirects")
    is_valid: bool = Field(False, description="Whether URL is valid")
    error_message: Optional[str] = Field(None, description="Error message if invalid")
    
    @validator("is_valid", always=True)
    def set_is_valid(cls, v: bool, values: Dict) -> bool:
        """Set is_valid based on status."""
        return values.get("status") == ValidationStatus.VALID


# Protocol for validation service
class URLValidationService(Protocol):
    """Protocol defining URL validation service interface."""
    
    async def validate(self, url: str) -> ValidationResult:
        """Validate a URL asynchronously.
        
        Args:
            url: The URL to validate
            
        Returns:
            ValidationResult with status and details
        """
        ...


# Implementation of URL validator
class URLValidator:
    """URL validator implementation for crawl4ai-mcp.
    
    Validates URLs according to project requirements including 
    scheme validation, format checking, length restrictions,
    and optional connection validation.
    """
    
    def __init__(
        self,
        allowed_schemes: Optional[List[str]] = None,
        max_length: int = MAX_URL_LENGTH,
        validate_connection: bool = False,
        follow_redirects: bool = True,
    ) -> None:
        """Initialize the URL validator.
        
        Args:
            allowed_schemes: List of allowed URL schemes (defaults to http, https)
            max_length: Maximum allowed URL length
            validate_connection: Whether to validate URL is accessible
            follow_redirects: Whether to follow redirects when validating
        """
        self.allowed_schemes = allowed_schemes or ["http", "https"]
        self.max_length = max_length
        self.validate_connection = validate_connection
        self.follow_redirects = follow_redirects
        self._logger = logging.getLogger(__name__)

    def validate(self, url: str) -> ValidationResult:
        """Validate a URL synchronously.
        
        Args:
            url: The URL to validate
            
        Returns:
            ValidationResult with status and details
            
        Raises:
            ValidationError: If the URL is invalid
        """
        if not url:
            return ValidationResult(
                url=url,
                status=ValidationStatus.INVALID_FORMAT,
                error_message="URL cannot be empty",
            )
            
        # Check URL length
        if len(url) > self.max_length:
            return ValidationResult(
                url=url,
                status=ValidationStatus.TOO_LONG,
                error_message=f"URL exceeds maximum length of {self.max_length}",
            )
            
        # Parse and validate URL format
        try:
            parsed_url = urlparse(url)
            
            # Check scheme
            if parsed_url.scheme not in self.allowed_schemes:
                return ValidationResult(
                    url=url,
                    status=ValidationStatus.INVALID_SCHEME,
                    error_message=f"URL scheme must be one of: {', '.join(self.allowed_schemes)}",
                )
                
            # Check for required components
            if not parsed_url.netloc:
                return ValidationResult(
                    url=url,
                    status=ValidationStatus.INVALID_FORMAT,
                    error_message="URL must contain a network location (domain)",
                )
                
            # Normalize the URL
            normalized = normalize_url(parsed_url)
            
            # Optionally validate connection
            if self.validate_connection:
                # Implementation would check the URL is accessible
                pass
                
            return ValidationResult(
                url=url,
                status=ValidationStatus.VALID,
                normalized_url=normalized,
                final_url=normalized,
                is_valid=True,
            )
                
        except Exception as e:
            self._logger.warning(f"URL validation failed: {str(e)}")
            return ValidationResult(
                url=url,
                status=ValidationStatus.INVALID_FORMAT,
                error_message=f"URL parsing failed: {str(e)}",
            )
    
    async def validate_async(self, url: str) -> ValidationResult:
        """Validate a URL asynchronously.
        
        Provides the same validation as the synchronous version but
        allows for non-blocking validation, including connection testing.
        
        Args:
            url: The URL to validate
            
        Returns:
            ValidationResult with status and details
        """
        # Basic validation first (synchronous)
        result = self.validate(url)
        if not result.is_valid:
            return result
            
        # If connection validation is required, do it asynchronously
        if self.validate_connection:
            try:
                async with httpx.AsyncClient(
                    follow_redirects=self.follow_redirects,
                    timeout=DEFAULT_TIMEOUT_SECONDS,
                ) as client:
                    response = await client.head(
                        result.normalized_url,
                        headers={"User-Agent": DEFAULT_USER_AGENT},
                    )
                    
                    # Update with redirect information if applicable
                    if self.follow_redirects and response.url != result.normalized_url:
                        result.final_url = str(response.url)
                        result.redirect_count = len(response.history)
                    
                    # Connection successful
                    return result
                    
            except httpx.HTTPStatusError as e:
                if 400 <= e.response.status_code < 500:
                    status = ValidationStatus.FORBIDDEN
                    msg = f"URL not accessible: {e.response.status_code}"
                else:
                    status = ValidationStatus.UNREACHABLE
                    msg = f"Server error: {e.response.status_code}"
                    
                return ValidationResult(
                    url=url,
                    status=status,
                    normalized_url=result.normalized_url,
                    error_message=msg,
                )
                
            except Exception as e:
                self._logger.warning(f"Connection validation failed: {str(e)}")
                return ValidationResult(
                    url=url,
                    status=ValidationStatus.UNREACHABLE,
                    normalized_url=result.normalized_url,
                    error_message=f"Connection failed: {str(e)}",
                )
        
        # No connection validation needed
        return result


# Utility functions
def normalize_url(parsed_url: Union[str, ParseResult]) -> str:
    """Normalize a URL to a standard format.
    
    Normalization includes:
    - Converting scheme to lowercase
    - Adding trailing slash to empty paths
    - Removing default ports
    - Sorting query parameters
    
    Args:
        parsed_url: URL to normalize, either as string or ParseResult
        
    Returns:
        Normalized URL as string
    """
    if isinstance(parsed_url, str):
        parsed_url = urlparse(parsed_url)
        
    # Normalize scheme
    scheme = parsed_url.scheme.lower()
    
    # Normalize netloc (lowercase)
    netloc = parsed_url.netloc.lower()
    
    # Remove default ports
    if (scheme == "http" and netloc.endswith(":80")) or (scheme == "https" and netloc.endswith(":443")):
        netloc = netloc.rsplit(":", 1)[0]
        
    # Ensure empty paths have trailing slash
    path = parsed_url.path
    if not path:
        path = "/"
        
    # Reconstruct the URL with normalized components
    normalized_parts = (scheme, netloc, path, parsed_url.params, parsed_url.query, parsed_url.fragment)
    return urlunparse(normalized_parts)
```

