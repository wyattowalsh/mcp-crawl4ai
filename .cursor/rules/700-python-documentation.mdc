// EXCELLENT: Well-documented module with Google style docstrings
```python
"""URL validation and normalization for web crawling operations.

This module provides functions and classes for validating and normalizing URLs
for use with the crawl4ai-mcp crawler system. It handles validation according
to RFC 3986 and implements custom validation rules specific to the crawler's
requirements.

Key components:
    URLValidator: Main class for URL validation and normalization
    normalize_url: Function for standardizing URL format
    ValidationError: Custom exception for validation failures

Example:
    ```python
    from crawl4ai_mcp.urls import URLValidator

    validator = URLValidator(allowed_schemes=["http", "https"])
    try:
        normalized_url = validator.validate("example.com")
        print(f"Normalized URL: {normalized_url}")
    except ValidationError as e:
        print(f"Invalid URL: {e}")
    ```

Note:
    This module only validates URL format and structure, not accessibility.
    For checking if URLs are accessible, use the network module.
"""

import logging
import re
from enum import Enum
from typing import Dict, List, Optional, Set, Tuple, Union
from urllib.parse import ParseResult, urlparse, urlunparse

from pydantic import BaseModel, Field, validator

from crawl4ai_mcp.utils.text import normalize_text


# Constants
MAX_URL_LENGTH = 2048
DEFAULT_TIMEOUT_SECONDS = 30.0


class ValidationError(Exception):
    """Exception raised when URL validation fails.
    
    Attributes:
        message: Explanation of why validation failed
        url: The URL that failed validation
        code: Optional error code for programmatic handling
    """
    
    def __init__(self, message: str, url: str, code: Optional[str] = None) -> None:
        """Initialize the ValidationError.
        
        Args:
            message: Error message explaining the validation failure
            url: The URL that failed validation
            code: Optional error code for programmatic handling
        """
        self.message = message
        self.url = url
        self.code = code
        super().__init__(f"{message}: {url}")


class ValidationStatus(str, Enum):
    """Enumeration of URL validation status results."""
    
    VALID = "valid"
    INVALID_SCHEME = "invalid_scheme"
    INVALID_FORMAT = "invalid_format"
    TOO_LONG = "too_long"
    UNREACHABLE = "unreachable"
    FORBIDDEN = "forbidden"


class ValidationResult(BaseModel):
    """Result of URL validation operation.
    
    Contains validation status, the normalized URL if valid,
    and detailed error information if invalid.
    
    Attributes:
        url: Original URL that was validated
        status: Validation status enum
        normalized_url: Normalized URL if valid, None otherwise
        is_valid: Whether the URL is valid
        error_message: Error message if invalid, None otherwise
    """
    
    url: str = Field(..., description="Original URL that was validated")
    status: ValidationStatus = Field(..., description="Validation status")
    normalized_url: Optional[str] = Field(None, description="Normalized URL if valid")
    is_valid: bool = Field(False, description="Whether URL is valid")
    error_message: Optional[str] = Field(None, description="Error message if invalid")
    
    @validator("is_valid", always=True)
    def set_is_valid(cls, v: bool, values: Dict) -> bool:
        """Set is_valid based on status.
        
        Args:
            v: Current is_valid value
            values: Other field values
            
        Returns:
            Updated is_valid value based on status
        """
        return values.get("status") == ValidationStatus.VALID


class URLValidator:
    """URL validator for crawl4ai-mcp.
    
    Validates URLs according to project requirements including 
    scheme validation, format checking, and length restrictions.
    
    Attributes:
        allowed_schemes: List of allowed URL schemes
        max_length: Maximum allowed URL length
        follow_redirects: Whether to follow redirects when validating
    """
    
    def __init__(
        self,
        allowed_schemes: Optional[List[str]] = None,
        max_length: int = MAX_URL_LENGTH,
        follow_redirects: bool = True,
    ) -> None:
        """Initialize the URL validator.
        
        Args:
            allowed_schemes: List of allowed URL schemes (defaults to http, https)
            max_length: Maximum allowed URL length
            follow_redirects: Whether to follow redirects when validating
        """
        self.allowed_schemes = allowed_schemes or ["http", "https"]
        self.max_length = max_length
        self.follow_redirects = follow_redirects
        self._logger = logging.getLogger(__name__)

    def validate(self, url: str) -> ValidationResult:
        """Validate a URL.
        
        Checks if the URL meets the following criteria:
        - Has an allowed scheme (http, https by default)
        - Has a valid format according to RFC 3986
        - Doesn't exceed the maximum length
        
        Args:
            url: The URL to validate
            
        Returns:
            ValidationResult with status and details
            
        Raises:
            ValidationError: If validation fails with critical error
            
        Examples:
            >>> validator = URLValidator()
            >>> result = validator.validate("https://example.com")
            >>> result.is_valid
            True
            >>> result = validator.validate("invalid://example.com")
            >>> result.is_valid
            False
        """
        if not url:
            return ValidationResult(
                url="",
                status=ValidationStatus.INVALID_FORMAT,
                error_message="URL cannot be empty",
            )
            
        # Check URL length
        if len(url) > self.max_length:
            return ValidationResult(
                url=url,
                status=ValidationStatus.TOO_LONG,
                error_message=f"URL exceeds maximum length of {self.max_length}",
            )
            
        # Parse and validate URL format
        try:
            parsed_url = urlparse(url)
            
            # Check scheme - must be in allowed schemes
            if parsed_url.scheme not in self.allowed_schemes:
                return ValidationResult(
                    url=url,
                    status=ValidationStatus.INVALID_SCHEME,
                    error_message=f"URL scheme must be one of: {', '.join(self.allowed_schemes)}",
                )
                
            # Check for required components - must have netloc
            if not parsed_url.netloc:
                return ValidationResult(
                    url=url,
                    status=ValidationStatus.INVALID_FORMAT,
                    error_message="URL must contain a network location (domain)",
                )
                
            # Normalize the URL
            normalized = normalize_url(parsed_url)
                
            return ValidationResult(
                url=url,
                status=ValidationStatus.VALID,
                normalized_url=normalized,
                is_valid=True,
            )
                
        except Exception as e:
            # Log the exception for debugging, but return a friendly error message
            self._logger.warning(f"URL validation failed: {str(e)}")
            return ValidationResult(
                url=url,
                status=ValidationStatus.INVALID_FORMAT,
                error_message=f"URL parsing failed: {str(e)}",
            )


def normalize_url(parsed_url: Union[str, ParseResult]) -> str:
    """Normalize a URL to a standard format.
    
    Normalization includes:
    - Converting scheme to lowercase
    - Adding trailing slash to empty paths
    - Removing default ports
    - Ensuring proper URL encoding
    
    Args:
        parsed_url: URL to normalize, either as string or ParseResult
        
    Returns:
        Normalized URL as string
        
    Examples:
        >>> normalize_url("HTTP://Example.COM")
        'http://example.com/'
        >>> normalize_url("http://example.com:80")
        'http://example.com/'
    """
    if isinstance(parsed_url, str):
        parsed_url = urlparse(parsed_url)
        
    # Normalize scheme to lowercase
    scheme = parsed_url.scheme.lower()
    
    # Normalize netloc (lowercase)
    netloc = parsed_url.netloc.lower()
    
    # Remove default ports
    if (scheme == "http" and netloc.endswith(":80")) or (
        scheme == "https" and netloc.endswith(":443")
    ):
        netloc = netloc.rsplit(":", 1)[0]
        
    # Ensure empty paths have trailing slash
    path = parsed_url.path
    if not path:
        path = "/"
        
    # Reconstruct the URL with normalized components
    normalized_parts = (scheme, netloc, path, parsed_url.params, parsed_url.query, parsed_url.fragment)
    return urlunparse(normalized_parts)
```

