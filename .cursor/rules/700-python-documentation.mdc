                raise ValidationError(f"Invalid scheme, must be: {self.allowed_schemes}", url)
                
            # Check netloc
            if not parsed_url.netloc:
                raise ValidationError("Missing domain", url)
                
            # Return normalized URL
            return normalize_url(parsed_url)
                
        except Exception as e:
            self._logger.warning(f"Failed validation: {e}")
            raise ValidationError(str(e), url)

# Helper function
def normalize_url(parsed_url):
    if isinstance(parsed_url, str):
        parsed_url = urlparse(parsed_url)
        
    # Get parts
    scheme = parsed_url.scheme.lower()
    netloc = parsed_url.netloc.lower()
    
    # Handle ports
    if (scheme == "http" and netloc.endswith(":80")) or (scheme == "https" and netloc.endswith(":443")):
        netloc = netloc.rsplit(":", 1)[0]
        
    # Fix path
    path = parsed_url.path if parsed_url.path else "/"
        
    # Return full URL
    return urlunparse((scheme, netloc, path, parsed_url.params, parsed_url.query, parsed_url.fragment))
