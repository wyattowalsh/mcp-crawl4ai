class CrawlRequest(BaseModel):
    """Validated crawl request model with secure defaults."""
    
    url: str = Field(..., description="URL to crawl")
    depth: int = Field(1, ge=0, le=3, description="Crawl depth")
    follow_external: bool = Field(False, description="Whether to follow external links")
    api_key: SecretStr = Field(..., description="API key for authentication")
    
    # Server-side validation with explicit security controls
    @validator("url")
    def validate_url(cls, v: str) -> str:
        """Validate URL format and security.
        
        Ensures URLs use allowed schemes and domains.
        """
        try:
            parsed = urlparse(v)
            
            # Verify URL has valid scheme
            if parsed.scheme not in ["http", "https"]:
                raise ValueError("URL must use http or https scheme")
            
            # Check for localhost or internal IP access (SSRF prevention)
            hostname = parsed.netloc.lower()
            if hostname in ["localhost", "127.0.0.1", "::1"] or re.match(r"^192\.168\.", hostname):
                raise ValueError("Access to internal hosts is forbidden")
                
            return v
        except Exception as e:
            logger.warning(f"Invalid URL format: {e}")
            raise ValueError(f"Invalid URL format: {str(e)}")


async def process_crawl_request(
    request: CrawlRequest, user: User
) -> Dict[str, Union[str, List[str]]]:
    """Process a crawl request securely.
    
    Args:
        request: Validated crawl request
        user: Authenticated user
    
    Returns:
