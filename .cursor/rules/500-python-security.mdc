        ValueError: If request validation fails
        httpx.RequestError: If HTTP request fails
    """
    # Authorization check using user permissions
    if not user.has_permission("crawl:execute"):
        logger.warning(
            f"Authorization failure: User {user.id} attempted to crawl without permission"
        )
        raise PermissionError("You don't have permission to perform this action")
    
    # Audit logging for security events
    request_id = str(uuid.uuid4())
    logger.info(
        f"Crawl request {request_id} initiated by user {user.id} for URL {request.url}"
    )
    
    try:
        # Secure HTTP client configuration
        async with httpx.AsyncClient(
            timeout=30.0,
            follow_redirects=True,
            # Explicit security headers
            headers={
                "User-Agent": get_settings().user_agent,
                "Accept": "text/html,application/xhtml+xml",
            },
        ) as client:
            # Execute HTTP request with proper error handling
            response = await client.get(request.url)
            response.raise_for_status()
            
            # Content sanitization for security
            sanitized_content = sanitize_html(response.text)
            
            # Parse content securely
            # ... content processing logic ...
            
            # Store results using parameterized queries
            async with get_db_session() as session:
                await store_crawl_result(
                    session=session,
                    user_id=user.id,
                    url=request.url,
                    content=sanitized_content,
                    request_id=request_id,
                )
            
            return {
                "request_id": request_id,
                "url": request.url,
                "status": "success",
                "content_length": len(sanitized_content),
            }
            
    except httpx.HTTPStatusError as e:
        # Secure error handling - logged with details but return sanitized message
        logger.error(
            f"HTTP error during crawl {request_id}: {e.response.status_code} for {request.url}"
        )
        return {
            "request_id": request_id,
            "url": request.url,
            "status": "error",
            "message": f"HTTP error: {e.response.status_code}",
        }
        
    except Exception as e:
        # Generic error handling with appropriate logging
        logger.exception(f"Error during crawl {request_id}: {str(e)}")
        return {
            "request_id": request_id,
            "url": request.url,
            "status": "error",
            "message": "An error occurred during processing",
        }


async def store_crawl_result(
    session: AsyncSession,
    user_id: int,
    url: str,
    content: str,
    request_id: str,
) -> None:
    """Store crawl results using parameterized queries.
    
    Uses SQLAlchemy parameterization to prevent SQL injection.
    """
    # Explicitly use parameterized query
    stmt = sa.text(
        """
        INSERT INTO crawl_results (user_id, url, content, request_id, created_at)
        VALUES (:user_id, :url, :content, :request_id, NOW())
        """
    )
    
    # Execute with named parameters (SQL injection prevention)
    await session.execute(
        stmt,
        {
            "user_id": user_id,
            "url": url,
            "content": content,
            "request_id": request_id,
        },
    )
    await session.commit()
